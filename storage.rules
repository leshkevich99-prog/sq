rules_version = '2';
service cloud.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "leshkevich.99@gmail.com" ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isPilot() {
      return isAuthenticated() && (
        isAdmin() ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'pilot')
      );
    }

    // Доступ к папке пользователя (техпаспорт и т.д.) - работает сразу!
    match /cars/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Фото поручений
    match /requests/{requestId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPilot();
    }

    // Рекомендации по машинам
    match /recommendations/{carId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPilot();
    }

    // Чеки
    match /receipts/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isPilot();
    }

    // Все остальное - только админы
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
